buff = {}

#Kiss cooldown settings (in ticks, 20 ticks = 1 second)
#Cooldown decreases as the maid's favorability level increases
[cooldown]
	#Cooldown at favorability level 0 (default: 100 = 5 seconds)
	#Range: 0 ~ 6000
	level0 = 100
	#Cooldown at favorability level 1 (default: 60 = 3 seconds)
	#Range: 0 ~ 6000
	level1 = 60
	#Cooldown at favorability level 2 (default: 20 = 1 second)
	#Range: 0 ~ 6000
	level2 = 20
	#Cooldown at favorability level 3 / max (default: 0 = no cooldown)
	#Range: 0 ~ 6000
	level3 = 0

#Favorability gain settings
[favorability]
	#Favorability points gained per kiss (default: 3)
	#Range: 1 ~ 100
	points = 3
	#Favorability gain cooldown in ticks (default: 600 = 30 seconds)
	#This is separate from the interaction cooldown - prevents favorability farming
	#Range: 0 ~ 72000
	cooldownTicks = 600

#Bond ability P point costs
#Defaults are tuned for Touhou Little Maid's normal P point acquisition pace
[bondCosts]
	#P point cost for Lap Pillow
	#Range: 0 ~ 9999
	lapPillow = 8
	#P point cost for Emergency Heal
	#Range: 0 ~ 9999
	emergencyHeal = 3
	#P point cost for Morning Kiss
	#Range: 0 ~ 9999
	morningKiss = 12
	#P point cost for YSM Action
	#Range: 0 ~ 9999
	ysmAction = 16
	#P point cost for Random Gift
	#Range: 0 ~ 9999
	randomGift = 6
	#Maximum distance to gift items after unlock
	#Range: 1 ~ 64
	randomGiftMaxDistance = 6
	#Maximum distance to start lap pillow
	#Range: 1 ~ 16
	lapPillowMaxDistance = 3
	#Show particles for Eternal Utopia during lap pillow (default: true)
	lapPillowEternalUtopiaParticles = true

	#Automatic random gift behaviour after unlock
	[bondCosts.randomGiftBehavior]
		#Enable the automatic random gift behavior after unlock
		enabled = true
		#Real-time minutes required to prepare one gift
		#Range: 1 ~ 1440
		intervalRealMinutes = 20
		#Maximum number of queued gifts per maid
		#Range: 1 ~ 64
		maxQueuedGifts = 7
		#Range around the player to search for nearby gift maids
		#Range: 4 ~ 128
		deliverySearchRange = 24
		#Distance at which the maid can throw the gift
		#Range: 0.5 ~ 16.0
		deliveryReachDistance = 2.25
		#Minimum ticks between consecutive automatic gift throws from the same maid
		#Range: 0 ~ 24000
		deliveryCooldownTicks = 40
		#Timeout for a single automatic gift delivery pathfinding task
		#Range: 20 ~ 24000
		pathfindTimeoutTicks = 200
		#Show action bar text when a maid throws a gift
		showActionBar = true
		#Automatically sample a batch of non-vanilla mod items into the gift pool
		includeModItems = true
		#How many non-vanilla mod items are auto-sampled into the gift pool
		#Range: 0 ~ 2048
		autoModSampleSize = 96

	#Morning Kiss behavior after unlock
	[bondCosts.morningKissBehavior]
		#Enable Morning Kiss after the ability is unlocked
		enabled = true
		#Required maid favorability level to use Morning Kiss
		#Range: 0 ~ 3
		requiredFavorabilityLevel = 3
		#Maximum distance to call a maid for Morning Kiss
		#Range: 1 ~ 128
		maxDistance = 16
		#Morning Kiss timeout in ticks
		#Range: 20 ~ 2400
		timeoutTicks = 200
		#Allowed in-world time ranges for Morning Kiss, using 24-hour time
		#Examples: 06:00-08:00, 18:00-20:00
		#Optional dialogue bucket prefix is supported: morning@06:00-08:00, evening@18:00-20:00
		#Legacy tick ranges like 0-2000 are still accepted for compatibility
		allowedTimeRanges = ["06:00-08:00", "18:00-20:00"]
		#Minimum number of kisses performed in one Morning Kiss sequence
		#Range: 1 ~ 3
		minKissCount = 1
		#Maximum number of kisses performed in one Morning Kiss sequence
		#Range: 1 ~ 3
		maxKissCount = 3
		#Ticks between consecutive kisses in one Morning Kiss sequence
		#Range: 1 ~ 200
		kissIntervalTicks = 16
		#Apply Maid's Prayer during Morning Kiss
		applyMaidsPrayer = true
		#Maid's Prayer duration applied by Morning Kiss in ticks
		#Range: 20 ~ 72000
		maidsPrayerDurationTicks = 600
		#Where Morning Kiss prompts and dialogue are shown
		#Allowed values: action_bar, chat
		messageDisplayMode = "action_bar"
		#Show Morning Kiss dialogue above the maid with Touhou Little Maid chat bubbles when possible
		#If disabled, dialogue uses messageDisplayMode instead
		dialogueChatBubbleEnabled = true
		#Enable Morning Kiss AI-generated dialogue integration
		#Requires Touhou Little Maid LLM to be enabled and configured on the maid
		aiDialogueEnabled = false
		#Language used for Morning Kiss AI dialogue pregeneration, live fallback, and generated TTS requests
		#Use tlm/auto/default to follow Touhou Little Maid's per-maid chat/TTS language; set zh_cn, en_us, ja_jp, etc. to override
		aiDialogueLanguage = "tlm"
		#Prompt template for Morning Kiss AI-generated dialogue
		#Placeholders: {maid}, {player}, {pool}, {time}
		aiDialoguePrompt = "你正在扮演 Minecraft 中名为 {maid} 的女仆。现在是 {pool} 时段，你刚给玩家 {player} 送上早安吻或晚安吻。请只输出自然、温柔、适合显示在游戏内的简短台词，不要解释，不要添加引号。"
		#Pregenerate AI Morning Kiss dialogue outside active Morning Kiss time windows to reduce trigger latency
		aiDialoguePregenerateEnabled = true
		#If no pregenerated line is cached, request one live through Touhou Little Maid chat during Morning Kiss
		#This can add visible latency, so it is disabled by default
		aiDialogueImmediateFallbackEnabled = false
		#Generate remote TTS OGG voice for pregenerated Morning Kiss dialogue when the maid has TTS configured
		#System/local TTS and non-OGG responses are ignored and fall back to text-only cached dialogue
		aiDialogueTtsEnabled = true
		#Ticks between AI dialogue pregeneration scans
		#Range: 20 ~ 72000
		aiDialogueScanIntervalTicks = 1200
		#Range around each player to find owned maids for AI dialogue pregeneration
		#Range: 1 ~ 128
		aiDialogueScanDistance = 16
		#Target number of pregenerated Morning Kiss lines kept per maid and time pool
		#Range: 1 ~ 8
		aiDialogueCacheTargetPerPool = 4
		#Consume one pregenerated cache entry when Morning Kiss uses it
		#Set false to reuse generated dialogue/voice until clear_ai_cache is run, saving LLM/TTS tokens
		aiDialogueCacheConsumeOnUse = false
		#Enable verbose debug logs for Morning Kiss AI dialogue pregeneration
		aiDialogueVerboseLog = false
		#Allow maids to proactively trigger Morning Kiss during allowed time windows
		autoEnabled = true
		#How often the server scans nearby loaded maids for proactive Morning Kiss
		#Range: 5 ~ 1200
		autoScanIntervalTicks = 40
		#How much of the current time window can be used for random proactive attempt scheduling
		#Range: 10 ~ 100
		autoWindowAttemptSpreadPercent = 70
		#When true, proactive Morning Kiss failures stay silent instead of notifying the player
		autoSilentFailure = true
		#When true, all eligible nearby maids may proactively trigger Morning Kiss in the same time window one after another
		#When false, only one maid is selected for the whole time window
		autoAllowAllEligibleMaids = true
		#Allow only one active Morning Kiss task per player at a time
		autoSingleActiveTaskPerPlayer = true

	#Emergency rescue behaviour after unlock
	[bondCosts.emergencyRescueBehavior]
		#Master switch for emergency rescue interception
		enabled = true
		#Emergency rescue trigger threshold in health points
		#Range: 1 ~ 20
		healthThreshold = 4
		#Refresh rescue charges by Minecraft date/daytime progression instead of total game uptime
		#When enabled, sleeping to the next day or /time add 24000 can refresh charges
		refreshByDayTime = true
		#How many rescue charges each unlocked maid contributes on daily refresh
		#Range: 1 ~ 16
		chargesPerMaid = 1
		#Default value of common voice fallback for rescue custom voice profiles
		commonFallbackDefault = true
		#Seconds between server rescue predefined sound folder scans
		#Range: 5 ~ 3600
		syncScanIntervalSeconds = 30
		#Verbose logs for rescue sound sync and playback fallback
		syncVerboseLog = true
		#Additional X-axis rotation offset for the rescue overlay maid shown in front of the player
		#Negative tilts backward, positive tilts forward
		#Range: -180 to 180 degrees
		#Range: -180.0 ~ 180.0
		overlayViewPitchOffset = 0.0
		#Additional Y-axis rotation offset for the rescue overlay maid shown in front of the player
		#Useful when you want the maid to face the screen more directly
		#Range: -180 to 180 degrees
		#Range: -180.0 ~ 180.0
		overlayViewYawOffset = 180.0
		#Additional Z-axis rotation offset for the rescue overlay maid shown in front of the player
		#Negative rolls left, positive rolls right
		#Range: -180 to 180 degrees
		#Range: -180.0 ~ 180.0
		overlayViewRollOffset = 0.0

0.0

#Maid's Prayer buff settings
#Triggered by kissing multiple times in a short window
[buff]
	#Enable the Maid's Prayer buff (default: true)
	enabled = true
	#Number of kisses needed to trigger the buff (default: 3)
	#Range: 1 ~ 20
	kissThreshold = 3
	#Time window in ticks to reach the kiss threshold (default: 200 = 10 seconds)
	#Range: 20 ~ 6000
	kissWindowTicks = 200
	#Buff duration in ticks (default: 600 = 30 seconds)
	#Range: 20 ~ 72000
	durationTicks = 600

	#Regeneration amplifier per favorability level (0 = I, 1 = II, etc.)
	#Higher levels can exceed vanilla limits — the power of love knows no bounds
	[buff.amplifier]
		#Amplifier at favorability level 0 (default: 0 = Regen I)
		#Range: 0 ~ 255
		level0 = 0
		#Amplifier at favorability level 1 (default: 1 = Regen II)
		#Range: 0 ~ 255
		level1 = 1
		#Amplifier at favorability level 2 (default: 2 = Regen III, beyond vanilla)
		#Range: 0 ~ 255
		level2 = 2
		#Amplifier at favorability level 3 (default: 4 = Regen V, far beyond vanilla)
		#Range: 0 ~ 255
		level3 = 4

